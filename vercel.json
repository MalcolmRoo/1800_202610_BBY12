{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "routes": [
    {
      "src": "/main.html",
      "dest": "/main.html"
    },
    {
      "src": "/createGrpForm.html",
      "dest": "/createGrpForm.html"
    },
    {
      "src": "/JoinGroup.html",
      "dest": "/JoinGroup.html"
    },
    {
      "src": "/myGroups.html",
      "dest": "/myGroups.html"
    },
    {
      "src": "/group.html",
      "dest": "/group.html"
    },
    {
      "src": "/Slide-Out-Menu/MyAccount.html",
      "dest": "/Slide-Out-Menu/MyAccount.html"
    },
    {
      "src": "/Slide-Out-Menu/settings.html",
      "dest": "/Slide-Out-Menu/settings.html"
    },
    {
      "src": "/report.html",
      "dest": "/report.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
